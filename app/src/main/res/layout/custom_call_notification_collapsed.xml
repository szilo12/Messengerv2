<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="74dp"
    android:background="#1D7EF0"
    android:padding="10dp">

    <ImageView
        android:id="@+id/notification_avatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="4dp"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_decline"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_decline_button"
            android:clickable="true"
            android:contentDescription="Elutasítás"
            android:focusable="true"
            android:padding="11dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call_decline" />

        <ImageView
            android:id="@+id/btn_accept"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_accept_button"
            android:clickable="true"
            android:contentDescription="Fogadás"
            android:focusable="true"
            android:padding="11dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call_accept" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp"
        android:layout_toEndOf="@id/notification_avatar"
        android:layout_toStartOf="@id/button_container"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Hívás"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notification_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Bejövő hívás"
            android:textColor="#DBEAFE"
            android:textSize="13sp" />
    </LinearLayout>
</RelativeLayout>
