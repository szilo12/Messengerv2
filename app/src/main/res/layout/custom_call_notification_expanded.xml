<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="128dp"
    android:background="@drawable/bg_notification_card"
    android:padding="12dp">

    <!-- Header Section (Avatar and Text) -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <!-- Avatar Left -->
        <ImageView
            android:id="@+id/notification_avatar"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_marginStart="4dp"
            android:scaleType="centerCrop" />

        <!-- Texts to the right of Avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/notification_avatar"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/notification_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olyna"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/notification_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bejövő videohívás..."
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Interactive Actions Row at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/header_layout"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Decline Option (Circle) -->
        <ImageView
            android:id="@+id/btn_decline"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_decline_button"
            android:src="@drawable/ic_call_decline"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Elutasítás" />

        <!-- Accept Option (Circle) -->
        <ImageView
            android:id="@+id/btn_accept"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_accept_button"
            android:src="@drawable/ic_call_accept"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Fogadás" />
    </LinearLayout>
</RelativeLayout>
