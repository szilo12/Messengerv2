<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="154dp"
    android:background="#1D7EF0"
    android:padding="14dp">

    <ImageView
        android:id="@+id/notification_avatar"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="4dp"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/notification_avatar"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="4dp"
        android:layout_toEndOf="@id/notification_avatar"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Hívás"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notification_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Bejövő hívás"
            android:textColor="#DBEAFE"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/action_row"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_decline"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginEnd="28dp"
            android:background="@drawable/bg_decline_button"
            android:clickable="true"
            android:contentDescription="Elutasítás"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call_decline" />

        <ImageView
            android:id="@+id/btn_accept"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_marginStart="28dp"
            android:background="@drawable/bg_accept_button"
            android:clickable="true"
            android:contentDescription="Fogadás"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call_accept" />
    </LinearLayout>
</RelativeLayout>
